# ── Opt-Oz environment variables ──────────────────────────────────────────────
# Copy to .env and fill in. Never commit .env.

# IBKR TWS / Gateway connection
# When running inside Docker, TWS runs on the host machine.
IBKR_HOST=host.docker.internal
IBKR_PORT=7497          # 7497 = paper, 4001 = live gateway
IBKR_CLIENT_ID=1

# ThetaData (historical EOD chains). Leave blank to skip; yfinance used instead.
THETADATA_API_KEY=

# Tastytrade (alternative broker — leave blank if using IBKR)
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=
TASTYTRADE_SANDBOX=true

# Risk-free rate override (decimal). If blank, system fetches 3-month T-bill.
RISK_FREE_RATE=

# Paper trading starting NAV (USD)
PAPER_NAV=25000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
